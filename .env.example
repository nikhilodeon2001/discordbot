# Copy this file to .env and fill in values for local development.
# For staging: use the staging Discord bot token + staging MongoDB URI.
# For prod: values are set via Heroku config vars, not this file.

# Discord
discord_token=
DISCORD_MINI_GAME_AUDIO_BOT_TOKEN=

# MongoDB
mongo_db_string=

# OpenAI
openai_api_key=

# Sentry
SENTRY_DSN=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2

# Third-party APIs
openweather_api_key=
googlemaps_api_key=
googletranslate_api_key=
webster_api_key=
webster_thes_api_key=
currency_api_key=
deepgram_api_key=

# Discord server config
# stage or prod — controls which server/channel IDs are used
ENVIRONMENT=stage
channel_id=

# Set to true locally to allow solo testing of multiplayer mini-games (okrasays, etc.)
# Leave unset on Heroku (defaults to false)
ALLOW_SOLO_TESTING=true
